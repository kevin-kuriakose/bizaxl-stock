{
    "name": "BA Stock Ledger Entry",
    "doctype": "DocType",
    "module": "BizAxl Stock",
    "autoname": "naming_series:",
    "naming_series": "SLE-.YYYY.-",
    "in_create": 0,
    "fields": [
        {"fieldname": "naming_series", "fieldtype": "Select", "options": "SLE-.YYYY.-"},
        {"fieldname": "item_code", "fieldtype": "Link", "label": "Item", "options": "BA Item", "reqd": 1, "in_list_view": 1},
        {"fieldname": "warehouse", "fieldtype": "Link", "label": "Warehouse", "options": "BA Warehouse", "reqd": 1, "in_list_view": 1},
        {"fieldname": "posting_date", "fieldtype": "Date", "label": "Posting Date", "reqd": 1, "in_list_view": 1},
        {"fieldname": "actual_qty", "fieldtype": "Float", "label": "Qty Change", "in_list_view": 1},
        {"fieldname": "qty_after_transaction", "fieldtype": "Float", "label": "Qty After", "in_list_view": 1},
        {"fieldname": "col1", "fieldtype": "Column Break"},
        {"fieldname": "incoming_rate", "fieldtype": "Currency", "label": "Incoming Rate"},
        {"fieldname": "valuation_rate", "fieldtype": "Currency", "label": "Valuation Rate"},
        {"fieldname": "stock_value", "fieldtype": "Currency", "label": "Stock Value"},
        {"fieldname": "voucher_type", "fieldtype": "Data", "label": "Voucher Type"},
        {"fieldname": "voucher_no", "fieldtype": "Data", "label": "Voucher No"},
        {"fieldname": "batch_no", "fieldtype": "Link", "label": "Batch No", "options": "BA Batch"},
        {"fieldname": "serial_no", "fieldtype": "Text", "label": "Serial No"},
        {"fieldname": "is_cancelled", "fieldtype": "Check", "label": "Is Cancelled", "default": "0"}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1},
        {"role": "Stock Manager", "read": 1},
        {"role": "Stock User", "read": 1}
    ]
}
